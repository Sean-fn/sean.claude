{
  "$schema" : "https:\/\/json.schemastore.org\/claude-code-settings.json",
  "alwaysThinkingEnabled" : true,
  "cleanupPeriodDays" : 90,
  "enabledPlugins" : {
    "gf-jira@tool-cc-forge" : true,
    "gf-slack@tool-cc-forge" : true
  },
  "env" : {
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL" : "1"
  },
  "feedbackSurveyState" : {
    "lastShownTime" : 1754106537142
  },
  "hooks" : {
    "Notification" : [
      {
        "hooks" : [
          {
            "command" : "afplay \"$(ls ~\/.claude\/_voices\/*.mp3 | sort -R | head -n 1)\"",
            "type" : "command"
          }
        ],
        "matcher" : ""
      },
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PermissionRequest" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "timeout" : 86400,
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PostToolUse" : [
      {
        "hooks" : [
          {
            "command" : "jq -r '.tool_input.file_path' | { read file_path; if echo \"$file_path\" | grep -q '\\.py$'; then pre-commit run --files  \"$file_path\" 2>\/dev\/null; fi; }",
            "type" : "command"
          }
        ],
        "matcher" : "Edit|MultiEdit|Write"
      },
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PreCompact" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "auto"
      },
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "manual"
      }
    ],
    "PreToolUse" : [
      {
        "hooks" : [
          {
            "command" : "python -c \"import json, sys; data=json.load(sys.stdin); path=data.get('tool_input',{}).get('file_path',''); sys.exit(2 if any(p in path for p in ['.env', '.git\/', 'secrets.env']) else 0)\"",
            "type" : "command"
          }
        ],
        "matcher" : "Edit|MultiEdit|Write"
      },
      {
        "hooks" : [
          {
            "command" : "jq -r '.tool_input.command' >> ~\/.claude\/_logs\/bash-command-log.txt",
            "type" : "command"
          }
        ],
        "matcher" : "Bash"
      },
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "SessionEnd" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ],
    "SessionStart" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ],
    "Stop" : [
      {
        "hooks" : [
          {
            "command" : "afplay \"$(ls ~\/.claude\/_voices\/*.mp3 | sort -R | head -n 1)\"",
            "type" : "command"
          },
          {
            "command" : "output=$(python3 $HOME\/.claude\/_hooks\/extract_mermaids.py); [ -n \"$output\" ] && echo \"$output\" | homo || true",
            "timeout" : 5,
            "type" : "command"
          }
        ],
        "matcher" : ""
      },
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ],
    "SubagentStop" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ],
    "UserPromptSubmit" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy" : false,
  "language" : "繁體中文",
  "permissions" : {
    "allow" : [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git describe:*)",
      "Bash(jira me:*)",
      "Bash(jira issue view:*)",
      "Bash(jira issue list:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)"
    ],
    "defaultMode" : "plan",
    "deny" : [

    ]
  },
  "statusLine" : {
    "command" : "python3 \/Users\/sean\/.claude\/scripts\/usage_statusline.py",
    "type" : "command"
  }
}